const types = [
  "Fire Group",
  "Medical Group",
  "Rescue Group",
  "Blood Support Team",
  "Disaster Response Team",
  "Transport Team",
  "Women Safety Team"
];

const descriptions = {
  "Fire Group": "Local fire response team",
  "Medical Group": "Volunteer medics and first aid",
  "Rescue Group": "Emergency rescue and transport",
  "Blood Support Team": "Blood donor coordination",
  "Disaster Response Team": "Flood and cyclone emergency support",
  "Transport Team": "Patient transportation volunteers",
  "Women Safety Team": "Women and child safety support"
};

const names = [
  "Murugan","Latha","Vignesh","Kumar","Anbu","Suresh","Priya",
  "Ramesh","Deepak","Saravanan","Harini","Karthik","Bala",
  "Keerthana","Mohan","Divya","Prakash","Lavanya","Hari","Raja"
];

const volunteers = [];

for (let i = 1; i <= 100; i++) {
  const type = types[i % types.length];

  volunteers.push({
    id: `V${i}`,
    name: `${type} ${Math.ceil(i / types.length)}`,
    description: descriptions[type],
    members: [
      names[(i * 2) % names.length],
      names[(i * 2 + 1) % names.length],
      names[(i * 2 + 2) % names.length]
    ],
    capacity: Math.floor(Math.random() * 10) + 6
  });
}

console.log(JSON.stringify(volunteers, null, 2));
