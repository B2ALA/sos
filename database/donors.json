    phone: `+91 9${Math.floor(100000000 + Math.random() * 900000000)}`,
    location: locations[i % locations.length],
    lastDonation: `2026-${String((i % 12) + 1).padStart(2, "0")}-${String((i % 28) + 1).padStart(2, "0")}`,
    available: Math.random() > 0.3
  };

  donors.push(donor);
}

